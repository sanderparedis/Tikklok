rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprints
    function isValidWorkEntry(data) {
      return data.keys().hasAll(['id', 'date', 'startTime', 'endTime', 'breakTime', 'createdAt', 'updatedAt'])
        && data.keys().size() >= 7 && data.keys().size() <= 10
        && data.id is string && data.id.size() <= 128
        && data.date is string && data.date.size() == 10
        && data.startTime is string && data.startTime.size() == 5
        && data.endTime is string && data.endTime.size() == 5
        && data.breakTime is number
        && (!data.keys().contains('isFreeDay') || data.isFreeDay is bool)
        && (!data.keys().contains('freeDayType') || (data.freeDayType is string && data.freeDayType.size() <= 100))
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidTravelEntry(data) {
      return data.keys().hasAll(['id', 'date', 'description', 'distance', 'type', 'createdAt', 'updatedAt'])
        && data.keys().size() == 7
        && data.id is string && data.id.size() <= 128
        && data.date is string && data.date.size() == 10
        && data.description is string && data.description.size() <= 500
        && data.distance is number
        && data.type in ['auto', 'fiets']
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidUserTimer(data) {
      return data.keys().hasAll(['isActive', 'startTime'])
        && data.keys().size() >= 2
        && data.isActive is bool
        && (data.startTime == null || data.startTime is number);
    }

    // User Profile & Status
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserTimer(incoming());
      allow update: if isOwner(userId) && isValidUserTimer(incoming()) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['isActive', 'startTime']);

      // Work Entries
      match /workEntries/{entryId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(entryId) && isValidWorkEntry(incoming());
        allow delete: if isOwner(userId);
      }

      // Travel Entries
      match /travelEntries/{entryId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(entryId) && isValidTravelEntry(incoming());
        allow delete: if isOwner(userId);
      }
    }
  }
}
