{
  "entities": {
    "WorkEntry": {
      "title": "Work Entry",
      "description": "A record of time worked on a specific date.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "startTime": { "type": "string", "description": "HH:mm format" },
        "endTime": { "type": "string", "description": "HH:mm format" },
        "breakTime": { "type": "number", "description": "Break time in minutes" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "date", "startTime", "endTime", "breakTime"]
    },
    "TravelEntry": {
      "title": "Travel Entry",
      "description": "A record of professional travel.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "distance": { "type": "number" },
        "type": { "type": "string", "enum": ["auto", "fiets"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "date", "description", "distance", "type"]
    },
    "UserTimer": {
      "title": "User Timer State",
      "description": "The active timer state for a user.",
      "type": "object",
      "properties": {
        "isActive": { "type": "boolean" },
        "startTime": { "type": "number", "description": "Timestamp in ms" }
      },
      "required": ["isActive"]
    }
  },
  "firestore": {
    "/users/{userId}/workEntries/{entryId}": {
      "schema": "WorkEntry",
      "description": "Work history for a user."
    },
    "/users/{userId}/travelEntries/{entryId}": {
      "schema": "TravelEntry",
      "description": "Travel history for a user."
    },
    "/users/{userId}": {
      "schema": "UserTimer",
      "description": "User profile and active timer state."
    }
  }
}
